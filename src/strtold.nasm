;
; based on .nasm source file generated by soptcc.pl from fyi/c_strtold.c
; Compile to i386 ELF .o object: nasm -O999999999 -w+orphan-labels -f elf -o strtold.o strtold.nasm
;
; Uses: %ifdef CONFIG_PIC
;
; This implementation is believed to be correct and accurate. See accuracy
; tests in tests/test_strtold.c. The alternative Python implementation in
; fyi/strtold.py passes the same accuracy tests. The C implementation in
; fyi/c_strtold.c passes the same tests.
;
; !! TODO(pts): Optimize manually for size.
;

bits 32
cpu 386

%ifdef __UCLIBC__
  %define mini_errno __errno_location
  %ifndef mini_strtold
    %define mini_strtold strtold
  %endif
%endif

global mini_strtold
%ifidn __OUTPUT_FORMAT__, bin
section .text align=1
section .rodata align=1
section .data align=1
section .bss align=1
mini_errno equ +0x12345679
%else
section .text align=1
section .rodata align=4
section .data align=1
section .bss align=1
extern mini_errno
%endif

%ifdef __UCLIBC__
  %macro set_errno 1
		push eax
		call __errno_location
		mov dword [eax], %1
		pop eax
  %endm
%else
  %macro set_errno 1
		mov dword [mini_errno], %1
  %endm
%endif

section .text

%if 0  ; All calls inlined.
my_ldexpl:  ; long double my_ldexpl(long double x, int exp);
		fild dword [esp+0x10]
		fld tword [esp+4]
		fscale
		fstp st1
		ret
%endif

%if 0  ; All calls inlined.
; TODO(pts): Add it in separate .nasm file.
my_fmodl:  ; long double fmodl(long double x, long double y);
		fld tword [esp+0x10]
		fld tword [esp+4]
.again:		fprem
		fnstsw ax
		sahf
		jp .again
		fstp st1
		ret
%endif

scanexp_ESI:  ; static int64_t __usercall scanexp [EDX:EAX](const char *fp [in-out ESI]) [ruins ECX];
; Map of local variables: c-'0' is CH; neg is ECX; x is EDX.
		xor ecx, ecx  ; neg (CL) := 0 (positive).
		xor edx, edx  ; x := 0.
		lodsb
		sub al, '0'
		cmp al, '+'-'0'
		je .6
		cmp al, '-'-'0'
		jne .7
		inc ecx  ; neg := 1 (negative).
.6:
		lodsb
		sub al, '0'
		cmp al, '9'-'0'
		jbe .7
		dec esi  ; Unget the sign character.
.7:		cmp al, '9'-'0'
		jbe short .10
		dec esi
		dec esi
		xor eax, eax
		jmp short .done
.9:		mov ch, al
		mov eax, edx
		shl eax, 0x2
		add edx, eax
		add edx, edx
		movzx eax, ch
		add edx, eax
		lodsb
		sub al, '0'
		cmp al, '9'-'0'
		ja .15
.10:		cmp edx, 0xccccccb
		ja .15
		jmp short .9
.14:		lodsb
		sub al, '0'
		cmp al, '9'-'0'
		jbe .14
.15:		dec esi  ; fp -= 1.
		xchg eax, edx  ; result := x; EDX := junk.
		test cl, cl  ; neg.
		jz .done  ; Jump iff !neg.
		neg eax
.done:		cdq  ; EDX := sign_extend(EAX).
		ret

decfloat:  ; static long double decfloat(struct sfile *f, unsigned char c, int sign);
		push ebp  ; Save. !! Use registers EBX, EDI.
